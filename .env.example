# Copia in .env e adatta i valori.
# cp .env.example .env   (Linux/macOS)
# copy .env.example .env (Windows)

# ── Server ──
PORT=3847
TICK_MS=120
# Intervallo broadcast snapshot al browser (ms). Più alto = meno RAM in sessioni lunghe.
SNAPSHOT_MS=280

# ── Tier funzionali ──
# platform = API v2, policy lab, replay, SSO, Power BI, ecc.
# standard = solo simulazione + API v1
NEXUS_LICENSE_TIER=platform
NEXUS_BRAND_NAME=Nexus
# Opzionale, solo display commerciale:
# NEXUS_LIST_PRICE_EUR=0

# ── AI (opzionale — senza chiavi usa fallback locale) ──

# Ollama Cloud
# AI_PROVIDER=ollama
# OLLAMA_API_KEY=
# OLLAMA_BASE_URL=https://ollama.com
# OLLAMA_MODEL=gpt-oss:20b-cloud

# Ollama locale
# AI_PROVIDER=ollama
# OLLAMA_MODEL=llama3.1
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# OpenAI
# AI_PROVIDER=codex
# OPENAI_API_KEY=sk-...

# Gemini
# AI_PROVIDER=gemini
# GEMINI_API_KEY=

# ── Sicurezza API (opzionale in dev, consigliato in produzione) ──
# NEXUS_API_KEY_ADMIN=chiave-admin-min-32-caratteri
# NEXUS_API_KEY_VIEWER=chiave-sola-lettura
# NEXUS_API_KEY=...   # legacy, equivale ad admin

# Webhooks (Platform)
# NEXUS_WEBHOOK_URL=https://hooks.example.com/nexus
# NEXUS_WEBHOOK_SECRET=segreto-hmac

# ── PostgreSQL multi-tenant (opzionale, default = SQLite in data/) ──
# NEXUS_DATABASE_URL=postgres://nexus:secret@localhost:5432/nexus
# NEXUS_DEFAULT_TENANT=default
# Header HTTP: X-Nexus-Tenant: nome-cliente

# ── SSO Azure AD / OIDC (opzionale) ──
# NEXUS_OIDC_ISSUER=https://login.microsoftonline.com/{tenant-id}/v2.0
# NEXUS_OIDC_CLIENT_ID=
# NEXUS_OIDC_CLIENT_SECRET=
# NEXUS_OIDC_AUDIENCE=
# NEXUS_OIDC_REDIRECT_URI=http://localhost:3847/api/v2/auth/callback
# NEXUS_OIDC_ADMIN_ROLES=Nexus.Admin
# NEXUS_OIDC_VIEWER_ROLES=Nexus.Viewer
